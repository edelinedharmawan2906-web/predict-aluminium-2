# ============================================================
# .env.example — Salin file ini menjadi .env dan isi API key kamu
# JANGAN commit file .env ke Git!
# ============================================================

# --- FRED (Federal Reserve Economic Data) ---
# Daftar gratis di: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=6478bd4d80027de1de402942aa97de5a

# --- NewsAPI ---
# Daftar gratis di: https://newsapi.org/register
# Free tier: 100 request/hari, berita 1 bulan terakhir
NEWSAPI_KEY=563193ac23f24840879d31b95c0340d9

# --- Alpha Vantage (opsional, backup kurs) ---
# Daftar gratis di: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_KEY=4K9LV45ZAHVRU4L2

# --- Konfigurasi Data ---
# Tanggal mulai pengambilan data historis (minimal 7 tahun ke belakang)
DATA_START_DATE=2017-01-01
DATA_END_DATE=2024-12-31

# --- Path Output ---
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed
LOG_PATH=logs
